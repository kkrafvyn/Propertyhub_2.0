{
  "name": "baytmiftah",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:web": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "qa:local": "npm run typecheck && npm run test && npm run build && npm run release:check && npm audit --audit-level=high",
    "release:check": "node scripts/checkReleaseReadiness.cjs",
    "prod:env:check": "node scripts/checkProductionEnv.cjs",
    "prod:env:check:strict": "node scripts/checkProductionEnv.cjs --strict-all",
    "cap:sync": "npx cap sync",
    "android:add": "npx cap add android",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:gradle:debug": "cd android && gradlew.bat assembleDebug",
    "android:build": "npm run android:sync && npm run android:gradle:debug",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build:web && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:build:sim": "cd ios/App && xcodebuild -project App.xcodeproj -scheme App -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "supabase:deploy:payments": "node scripts/deploySupabasePayments.cjs"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
