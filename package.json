{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:web": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:check": "node scripts/checkReleaseReadiness.cjs",
    "cap:sync": "npx cap sync",
    "android:add": "npx cap add android",
    "android:sync": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:gradle:debug": "cd android && gradlew.bat assembleDebug",
    "android:build": "npm run android:sync && npm run android:gradle:debug",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build:web && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:build:sim": "cd ios/App && xcodebuild -project App.xcodeproj -scheme App -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "supabase:deploy:payments": "node scripts/deploySupabasePayments.cjs",
    "contracts:deploy-all": "hardhat run scripts/deployAll.cjs --network polygonAmoy",
    "contracts:deploy-all-mainnet": "hardhat run scripts/deployAll.cjs --network polygonMainnet",
    "contracts:deploy-token": "hardhat run scripts/deployPropertyToken.cjs --network polygonAmoy",
    "contracts:deploy-escrow": "hardhat run scripts/deployPropertyEscrow.cjs --network polygonAmoy",
    "contracts:deploy-ownership": "hardhat run scripts/deployPropertyOwnership.cjs --network polygonAmoy",
    "contracts:deploy-lease": "hardhat run scripts/deployPropertyLease.cjs --network polygonAmoy",
    "contracts:deploy-verification-registry": "hardhat run scripts/deployVerificationRegistry.cjs --network polygonAmoy",
    "contracts:test": "hardhat test",
    "contracts:verify": "hardhat verify"
  },
