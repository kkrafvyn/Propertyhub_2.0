# ─── Browser-safe (VITE_* is embedded in the JS bundle — only public keys here) ───
# Supabase publishable/anon key is meant to be public; access is limited by RLS policies.
VITE_SUPABASE_URL=https://ixmbfnfwpjwbfahqaftc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional — Stripe publishable key is also safe for the browser
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Server / CLI only — NEVER prefix with VITE_ (not for Vercel frontend env) ───
# Database password — local CLI migrations only (npm run supabase:link)
SUPABASE_DB_PASSWORD=

# Set VITE_* vars in Vercel → Environment Variables, then redeploy.
# Do NOT use tcnsqtnwyyufeupktkhs (edge functions not deployed on that project).

# ─── Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ───
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PAYSTACK_SECRET_KEY=sk_live_...
# SITE_URL=https://your-domain.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# RESEND_API_KEY=re_...
# EMAIL_FROM=BaytMiftah <noreply@yourdomain.com>
